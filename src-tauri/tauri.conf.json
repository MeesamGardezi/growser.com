{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Growser",
  "version": "0.1.0",
  "identifier": "com.growser.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Growser",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": true,
        "resizable": true
      }
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:growser.db"]
    }
  }
}
